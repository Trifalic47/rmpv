#!/bin/bash
set -euo pipefail

echo "== rmpv installer =="

# ─────────────────────────────
# detect repo
# ─────────────────────────────
REPO="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
echo "[i] Repo: $REPO"

# ─────────────────────────────
# detect user safely
# ─────────────────────────────
if [[ -n "${SUDO_USER:-}" ]]; then
    USER_HOME="$(eval echo "~$SUDO_USER")"
else
    USER_HOME="$HOME"
fi

CONFIG_DIR="$USER_HOME/.config"

echo "[i] User: $USER_HOME"

# ─────────────────────────────
# dependencies (ARCH SAFE)
# ─────────────────────────────
echo "[+] Checking dependencies..."

DEPS=(mpv yt-dlp mpc rmpc mpd rofi)

MISSING=()

for cmd in "${DEPS[@]}"; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        MISSING+=("$cmd")
    fi
done

if [[ ${#MISSING[@]} -ne 0 ]]; then
    echo "[!] Missing packages: ${MISSING[*]}"
    echo "[+] Installing via pacman..."
    sudo pacman -S --needed "${MISSING[@]}"
fi

# optional audio plugin (safe)
echo "[+] Optional: installing audio codecs"
sudo pacman -S --needed wildmidi timidity++ >/dev/null 2>&1 || true

# ─────────────────────────────
# clean MPD state (CRITICAL FIX)
# ─────────────────────────────
echo "[+] Resetting MPD state..."

pkill -9 mpd >/dev/null 2>&1 || true
systemctl --user stop mpd >/dev/null 2>&1 || true
systemctl --user stop mpd.socket >/dev/null 2>&1 || true

rm -rf "$USER_HOME/.local/share/mpd"
rm -rf "$USER_HOME/.cache/mpd"

mkdir -p "$USER_HOME/.local/share/mpd"
mkdir -p "$USER_HOME/.cache/mpd"
mkdir -p "$USER_HOME/.config/mpd/playlists"

# IMPORTANT: clean DB
rm -f "$USER_HOME/.local/share/mpd/database"

# ─────────────────────────────
# install configs
# ─────────────────────────────
echo "[+] Installing configs..."

mkdir -p "$CONFIG_DIR"

rm -rf "$CONFIG_DIR/mpv"
rm -rf "$CONFIG_DIR/rmpc"
rm -rf "$CONFIG_DIR/mpd"

cp -r "$REPO/dots/mpv"  "$CONFIG_DIR/mpv"
cp -r "$REPO/dots/rmpc" "$CONFIG_DIR/rmpc"
cp -r "$REPO/dots/mpd"  "$CONFIG_DIR/mpd"

# ─────────────────────────────
# FIXED MPD CONFIG GENERATION
# ─────────────────────────────
cat > "$CONFIG_DIR/mpd/mpd.conf" <<EOF
music_directory     "$USER_HOME/Music"

db_file            "$USER_HOME/.local/share/mpd/database"
playlist_directory "$USER_HOME/.config/mpd/playlists"
log_file           "$USER_HOME/.local/share/mpd/log"

pid_file           "$USER_HOME/.local/share/mpd/pid"
state_file         "$USER_HOME/.local/share/mpd/state"

auto_update        "yes"

bind_to_address    "127.0.0.1"
port               "6600"

audio_output {
    type "pipewire"
    name "PipeWire"
}
EOF

echo "[+] MPD config generated"

# ─────────────────────────────
# START MPD CLEANLY
# ─────────────────────────────
echo "[+] Starting MPD..."

mpd >/dev/null 2>&1 || true
sleep 1

mpc update >/dev/null 2>&1 || true

# ─────────────────────────────
# install binaries
# ─────────────────────────────
echo "[+] Installing binaries..."

sudo install -Dm755 "$REPO/bin/rmpv" /usr/local/bin/rmpv
sudo install -Dm755 "$REPO/bin/rmpv-play" /usr/local/bin/rmpv-play
sudo install -Dm755 "$REPO/bin/rmpv-search" /usr/local/bin/rmpv-search

# ─────────────────────────────
# done
# ─────────────────────────────
echo ""
echo "[✓] Installation complete"
echo ""
echo "Run:"
echo "  rmpv play <url>"
echo "  rmpv search <query>"
echo "  rmpv open"
