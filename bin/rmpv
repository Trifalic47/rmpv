#     echo "[!] rmpv not installed properly (missing config)"
#     exit 1
# fi
#
# source "$CONFIG"
#
# # ─────────────────────────────
# # dependency check
# # ─────────────────────────────
# for cmd in mpd mpc mpv yt-dlp rofi; do
