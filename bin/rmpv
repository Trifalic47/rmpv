#         exit 1
#     fi
# done
#
# # ─────────────────────────────
# # check MPD running
# # ─────────────────────────────
# is_mpd_running() {
#     pgrep mpd >/dev/null 2>&1
# }
#
# start_mpd() {
#     echo "[+] Starting MPD..."
#     mpd >/dev/null 2>&1 &
#     sleep 1
# }
#
# # ─────────────────────────────
# # check port
# # ─────────────────────────────
# check_mpd_port() {
#     ss -ltnp 2>/dev/null | grep -q 6600
# }
#
# # ─────────────────────────────
# # repair MPD
# # ─────────────────────────────
# repair_mpd() {
#     echo "[!] Repairing MPD state..."
#
#     pkill -9 mpd >/dev/null 2>&1 || true
#     systemctl --user stop mpd >/dev/null 2>&1 || true
#
#     rm -f "$HOME/.local/share/mpd/database"
#
#     start_mpd
# }
#
# # ─────────────────────────────
# # ensure MPD is alive
# # ─────────────────────────────
# if ! is_mpd_running; then
#     echo "[!] MPD not running"
#     start_mpd
# fi
#
# # double-check
# if ! check_mpd_port; then
#     echo "[!] MPD port not ready"
