#!/bin/bash

CMD="$1"
shift

case "$CMD" in
    play)
        rmpv-play "$@"
        ;;
    search)
        rmpv-search "$@"
        ;;
    open)
        rmpc
        ;;
    *)
        echo "Usage:"
        echo "  rmpv play <song/url/file>"
        echo "  rmpv search <query>"
        echo "  rmpv open"
        ;;
esac
